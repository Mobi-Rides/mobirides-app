{
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "files": {
      "include": ["**/*.ts"]
    },
    "options": {
      "useTabs": false,
      "lineWidth": 80,
      "indentWidth": 2
    }
  },
  "imports": {
    "supabase": "npm:@supabase/supabase-js@2.45.0",
    "resend": "npm:resend@3.4.0",
    "zod": "https://deno.land/x/zod@v3.23.8/mod.ts",
    "std/": "https://deno.land/std@0.224.0/"
  }
}

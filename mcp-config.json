{
    "mcpServers": {
        "supabase-remote": {
            "type": "http",
            "url": "https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_ID",
            "headers": {
                "Authorization": "Bearer YOUR_SUPABASE_PERSONAL_ACCESS_TOKEN"
            }
        },
        "linear": {
            "type": "command",
            "command": "npx",
            "args": [
                "@linear/mcp-server@latest"
            ],
            "env": {
                "LINEAR_API_KEY": "YOUR_LINEAR_PERSONAL_API_KEY"
            }
        }
    }
}